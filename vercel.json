{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci --omit=dev",
  "rewrites": [
    {
      "source": "/pergola",
      "destination": "/pergola-quick-reference.html"
    },
    {
      "source": "/pergola-quick-reference",
      "destination": "/pergola-quick-reference.html"
    }
  ],
  "functions": {
    "server.js": {
      "maxDuration": 300,
      "includeFiles": "node_modules/@sparticuz/chromium/**",
      "excludeFiles": "{main.js,preload.js,renderer/**,scripts/**,userscripts/**,STAFF_SETUP*,README.md,inspect_cart.js,product_cart_inspect*.js}"
    }
  }
}
