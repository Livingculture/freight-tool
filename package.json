{
  "name": "livingculture-freight-tool",
  "version": "0.1.0",
  "description": "Desktop helper for Living Culture delivery price lookup",
  "author": "Living Culture",
  "main": "main.js",
  "scripts": {
    "update": "git pull --ff-only origin main",
    "start": "electron .",
    "dev": "electron .",
    "start:web": "node server.js",
    "prepare-browser:mac": "node scripts/prepare-bundled-browser.js darwin",
    "prepare-browser:win": "node scripts/prepare-bundled-browser.js win32",
    "package:mac": "npm run prepare-browser:mac && electron-builder --mac",
    "package:win": "npm run prepare-browser:win && electron-builder --win",
    "install-playwright": "npx playwright install chromium"
  },
  "dependencies": {
    "express": "^4.18.4",
    "playwright": "^1.40.0"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "nz.co.livingculture.freightcosting",
    "productName": "Living Culture Freight Costing",
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "package.json",
      "package-lock.json",
      "renderer/**/*",
      "public/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": "zip",
      "extraResources": [
        {
          "from": "build-resources/darwin/ms-playwright",
          "to": "ms-playwright",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "win": {
      "target": "nsis",
      "extraResources": [
        {
          "from": "build-resources/win32/ms-playwright",
          "to": "ms-playwright",
          "filter": [
            "**/*"
          ]
        }
      ]
    }
  }
}
